# ── Alchemy ──────────────────────────────────────────
ALCHEMY_SEPOLIA_API_KEY=
ALCHEMY_SEPOLIA_WS_URL=wss://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ── Wallet (Sepolia testnet only) ────────────────────
WALLET_PRIVATE_KEY=
SAFE_ADDRESS=
SAFE_RECOVERY_ADDRESS=
ALCHEMY_SEPOLIA_HTTP_URL=

# ── Database ──────────────────────────────────────
DATABASE_URL=postgresql+psycopg2://icarus:icarus@localhost:5432/icarus

# ── Price Feed ─────────────────────────────────────────
ALCHEMY_API_KEY=
PRICE_FETCH_INTERVAL_SECONDS=30
PRICE_CACHE_TTL=30
PRICE_STALENESS_THRESHOLD_SECONDS=60

# ── Flashbots Protect (optional, P1b) ──────────────
FLASHBOTS_RPC_URL=

# ── Contract Allowlist (fail-closed: empty = reject all) ──
# Comma-separated hex addresses of permitted target contracts.
# When empty or unset, ALL transactions are rejected.
CONTRACT_ALLOWLIST=

# ── Spending Limits ─────────────────────────────────
SPENDING_CAP_PER_TX_WEI=500000000000000000
SPENDING_CAP_DAILY_WEI=2000000000000000000

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
STREAM_MAX_LENGTH=10000
STREAM_TRIM_INTERVAL_CYCLES=100

# ── Claude API (sentiment analysis) ──────────────────
ANTHROPIC_API_KEY=
AI_MONTHLY_COST_CAP_USD=10

# ── Risk Management ─────────────────────────────────
MAX_DRAWDOWN_PERCENT=20
PER_POSITION_LOSS_LIMIT_PERCENT=10
GAS_SPIKE_MULTIPLIER=3
TX_FAILURE_RATE_THRESHOLD=3
MIN_STABLECOIN_RESERVE_PERCENT=15
MAX_SINGLE_PROTOCOL_PERCENT=40
MAX_SINGLE_ASSET_PERCENT=60

# ── L2 Chain Listeners ──────────────────────────────
ALCHEMY_BASE_WS_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY
LISTEN_BASE_ENABLED=true

# ── Chain Config ─────────────────────────────────────
CHAIN_ID=11155111
NETWORK=sepolia
