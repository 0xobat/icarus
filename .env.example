# Icarus DeFi Agent — Environment Variables
# Copy to .env and fill in required values.
# Lines marked [required] must be set before running.

# ── Wallet [required] ─────────────────────────────────
WALLET_PRIVATE_KEY=0x_your_private_key_here
SAFE_ADDRESS=0x_your_safe_address_here
SAFE_RECOVERY_ADDRESS=0x_your_recovery_address_here

# ── Alchemy RPC [required] ────────────────────────────
ALCHEMY_API_KEY=your_alchemy_api_key_here
ALCHEMY_SEPOLIA_API_KEY=your_alchemy_sepolia_api_key_here
ALCHEMY_SEPOLIA_WS_URL=wss://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_SEPOLIA_HTTP_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_BASE_WS_URL=wss://base-mainnet.g.alchemy.com/v2/YOUR_KEY
ALCHEMY_BASE_HTTP_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# ── AI [required] ─────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your_key_here

# ── Database [required] ───────────────────────────────
DATABASE_URL=postgresql+psycopg2://icarus:icarus@localhost:5432/icarus
REDIS_URL=redis://localhost:6379

# ── Chain Config ───────────────────────────────────────
CHAIN_ID=11155111
NETWORK=sepolia

# ── Risk Limits (optional — sensible defaults built in) ─
MAX_DRAWDOWN_PERCENT=20
PER_POSITION_LOSS_LIMIT_PERCENT=10
GAS_SPIKE_MULTIPLIER=3
TX_FAILURE_RATE_THRESHOLD=3
MAX_SINGLE_PROTOCOL_PERCENT=40
MAX_SINGLE_ASSET_PERCENT=60
MIN_STABLECOIN_RESERVE_PERCENT=15
MIN_LIQUID_RESERVE=0.10

# ── Spending Limits (optional) ─────────────────────────
SPENDING_CAP_PER_TX_WEI=500000000000000000
SPENDING_CAP_DAILY_WEI=2000000000000000000
AI_MONTHLY_COST_CAP_USD=10

# ── Contract Allowlist (fail-closed: empty = reject all) ─
# Comma-separated hex addresses of permitted target contracts.
CONTRACT_ALLOWLIST=

# ── Protocol Addresses (optional — defaults provided) ──
AAVE_V3_POOL_ADDRESS=0x_aave_pool_address
AERODROME_ROUTER=0x_aerodrome_router_address
AERODROME_ROUTER_ADDRESS=0x_aerodrome_router_address
AERODROME_POOL_FACTORY=0x_aerodrome_pool_factory_address

# ── L2 Listeners (optional) ───────────────────────────
LISTEN_BASE_ENABLED=true

# ── Tuning (optional) ─────────────────────────────────
STREAM_MAX_LENGTH=10000
STREAM_TRIM_INTERVAL_CYCLES=100
PRICE_CACHE_TTL=30
PRICE_FETCH_INTERVAL_SECONDS=30
PRICE_STALENESS_THRESHOLD_SECONDS=60
TOTAL_CAPITAL=10000
RECONCILE_INTERVAL_SECONDS=1800
APPROVAL_TIMEOUT_HOURS=6

# ── Flashbots (optional) ──────────────────────────────
FLASHBOTS_RPC_URL=
